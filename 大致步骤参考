// 消费记录管理
Consumption consumptions[500];
int consumptionCount = 0;

int addConsumption(Cons cons) {
    if (consumptionCount >= 500) {
        printf("消费记录已满!\n");
        return 0;
    }
    
    consumptions[consumptionCount++] = cons;
    return 1;
}

float getTotalConsumption(char* studentId) {
    float total = 0.0;
    for (int i = 0; i < consumptionCount; i++) {
        if (strcmp(consumptions[i].studentId, studentId) == 0) {
            total += consumptions[i].amount;
        }
    }
    return total;
}
