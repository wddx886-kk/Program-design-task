int validateStudentId(char* id) {
    if (strlen(id) < 5 || strlen(id) > 20) {
        printf("学号长度应为5-20位!\n");
        return 0;
    }
    
    for (int i = 0; id[i] != '\0'; i++) {
        if (!isdigit(id[i])) {
            printf("学号只能包含数字!\n");
            return 0;
        }
    }
    return 1;
}
