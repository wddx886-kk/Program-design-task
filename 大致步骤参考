// 学生信息操作实现
Student students[100];  // 存储学生数组
int studentCount = 0;   // 学生数量

int addStudent(Student stu) {
    if (studentCount >= 100) {
        printf("学生数量已满!\n");
        return 0;
    }
    
    // 检查学号是否重复
    for (int i = 0; i < studentCount; i++) {
        if (strcmp(students[i].id, stu.id) == 0) {
            printf("学号已存在!\n");
            return 0;
        }
    }
    
    students[studentCount++] = stu;
    return 1;
}
 实现学生信息添加功能
 完成学号重复检查
 实现学生信息查找
 完成数据验证逻辑
第3-4天：数据操作核心

Student* findStudent(char* id) {
    for (int i = 0; i < studentCount; i++) {
        if (strcmp(students[i].id, id) == 0) {
            return &students[i];
        }
    }
    return NULL;
}

int deleteStudent(char* id) {
    for (int i = 0; i < studentCount; i++) {
        if (strcmp(students[i].id, id) == 0) {
            // 将后面的数据前移
            for (int j = i; j < studentCount - 1; j++) {
                students[j] = students[j + 1];
            }
            studentCount--;
            return 1;
        }
    }
    return 0;
}
